{
  "name": "web_search",
  "description": "Search the web for relevant information",
  "version": "1.0.0",
  "input_schema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Search query string",
        "minLength": 1
      },
      "config": {
        "type": "object",
        "properties": {
          "max_results": {
            "type": "integer",
            "description": "Maximum number of results",
            "default": 10,
            "minimum": 1,
            "maximum": 100
          },
          "safe_search": {
            "type": "boolean",
            "description": "Enable safe search",
            "default": true
          }
        }
      }
    },
    "required": ["query"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string"
      },
      "results": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "title": {"type": "string"},
            "url": {"type": "string", "format": "uri"},
            "snippet": {"type": "string"}
          }
        }
      },
      "count": {
        "type": "integer"
      }
    },
    "required": ["query", "results", "count"]
  },
  "errors": {
    "type": "object",
    "properties": {
      "timeout": {
        "code": "TIMEOUT",
        "message": "Request timed out"
      },
      "rate_limit": {
        "code": "RATE_LIMIT",
        "message": "Rate limit exceeded"
      },
      "invalid_query": {
        "code": "INVALID_QUERY",
        "message": "Invalid search query"
      }
    }
  }
}